ENV=dev
INTERNAL_AUTH_MODE=shared_token
INTERNAL_AUTH_TOKEN=dev-internal-token
INTERNAL_AUTH_IAM_AUDIENCE=
INTERNAL_AUTH_ALLOWED_SERVICE_ACCOUNTS=
MODEL_NAME=gemini-2.5-flash
RUNTIME_MODE=agent

AGENT_MODEL=google/gemini-2.5-flash
AGENT_BASE_URL=https://openrouter.ai/api/v1
AGENT_API_KEY=
AGENT_PROVIDER=openrouter
AGENT_ENABLED_TOOLSETS=safe
AGENT_DISABLED_TOOLSETS=
AGENT_ENABLE_GWS_READONLY_DEV=false
AGENT_MAX_ITERATIONS=20
AGENT_MAX_ITERATIONS_CAP=20
AGENT_ENFORCE_SAFE_TOOLSET_ONLY=true
AGENT_REQUIRE_CONFIRMATION_FOR_UNSAFE_TOOLSETS=true
AGENT_UNSAFE_TOOL_CONFIRMATION_PHRASE=CONFIRM_UNSAFE_TOOLS
AGENT_SKIP_CONTEXT_FILES=true
AGENT_SKIP_MEMORY=true
AGENT_FALLBACK_TO_COMPLETION=true

OPENAI_API_KEY=placeholder
OPENAI_BASE_URL=
OPENROUTER_API_KEY=
GCP_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
SYSTEM_PROMPT=You are Hermes, a helpful clinical assistant. Be concise and safe.
TEMPERATURE=0.2
MAX_OUTPUT_TOKENS=800
